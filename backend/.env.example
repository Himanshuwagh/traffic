DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
GOOGLE_API_KEY=your_google_maps_api_key
TOMTOM_API_KEY=your_tomtom_api_key
TOMTOM_TILE_DAILY_LIMIT=45000
TOMTOM_NONTILE_DAILY_LIMIT=2000
TOMTOM_DISCOVERY_ZOOM=12
TOMTOM_HOTSPOT_ZOOM=13
TOMTOM_FLOW_STYLE=relative-delay
TOMTOM_CONGESTION_THRESHOLD=0.35
TOMTOM_RAW_RETENTION_DAYS=7
TOMTOM_PEAK_WINDOWS=07:00-11:00,17:00-21:00
TOMTOM_TRACKING_INTERVAL_HOURS=3
TOMTOM_BASELINE_HOURS=13,22
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
